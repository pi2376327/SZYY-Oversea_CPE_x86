# This file is interpreted as shell script.
# Put your custom iptables rules here, they will
# be executed with each firewall (re-)start.

# Internal uci firewall chains are flushed and recreated on reload, so
# put custom rules into the root chains e.g. INPUT or FORWARD or into the
# special user chains, e.g. input_wan_rule or postrouting_lan_rule.

#Redsocks Redirect
iptables -t nat -N REDSOCKS
iptables -t nat -C REDSOCKS -d 0.0.0.0/8 -j RETURN || \
iptables -t nat -A REDSOCKS -d 0.0.0.0/8 -j RETURN
iptables -t nat -C REDSOCKS -d 10.0.0.0/8 -j RETURN || \
iptables -t nat -A REDSOCKS -d 10.0.0.0/8 -j RETURN
iptables -t nat -C REDSOCKS -d 127.0.0.0/8 -j RETURN || \
iptables -t nat -A REDSOCKS -d 127.0.0.0/8 -j RETURN
iptables -t nat -C REDSOCKS -d 169.254.0.0/16 -j RETURN || \
iptables -t nat -A REDSOCKS -d 169.254.0.0/16 -j RETURN
iptables -t nat -C REDSOCKS -d 172.16.0.0/12 -j RETURN || \
iptables -t nat -A REDSOCKS -d 172.16.0.0/12 -j RETURN
iptables -t nat -C REDSOCKS -d 192.168.0.0/16 -j RETURN || \
iptables -t nat -A REDSOCKS -d 192.168.0.0/16 -j RETURN
iptables -t nat -C REDSOCKS -d 224.0.0.0/4 -j RETURN || \
iptables -t nat -A REDSOCKS -d 224.0.0.0/4 -j RETURN
iptables -t nat -C REDSOCKS -d 240.0.0.0/4 -j RETURN || \
iptables -t nat -A REDSOCKS -d 240.0.0.0/4 -j RETURN
iptables -t nat -C REDSOCKS -s 192.168.151.0/24 -p tcp -j REDIRECT --to-ports 30001 || \
iptables -t nat -A REDSOCKS -s 192.168.151.0/24 -p tcp -j REDIRECT --to-ports 30001
iptables -t nat -C REDSOCKS -s 192.168.152.0/24 -p tcp -j REDIRECT --to-ports 30002 || \
iptables -t nat -A REDSOCKS -s 192.168.152.0/24 -p tcp -j REDIRECT --to-ports 30002
iptables -t nat -C REDSOCKS -s 192.168.153.0/24 -p tcp -j REDIRECT --to-ports 30003 || \
iptables -t nat -A REDSOCKS -s 192.168.153.0/24 -p tcp -j REDIRECT --to-ports 30003
iptables -t nat -C REDSOCKS -s 192.168.154.0/24 -p tcp -j REDIRECT --to-ports 30004 || \
iptables -t nat -A REDSOCKS -s 192.168.154.0/24 -p tcp -j REDIRECT --to-ports 30004

iptables -t nat -C PREROUTING ! -s 192.168.150.0/24 -p tcp -m set ! --match-set chnroute dst -j REDSOCKS || \
iptables -t nat -I PREROUTING ! -s 192.168.150.0/24 -p tcp -m set ! --match-set chnroute dst -j REDSOCKS
#iptables -t filter -C FORWARD -p udp -m udp ! --dport 53 -m set ! --match-set chnroute dst -j DROP || \
#iptables -t filter -I FORWARD -p udp -m udp ! --dport 53 -m set ! --match-set chnroute dst -j DROP

#iptables for dns
iptables -t nat -C PREROUTING -s 192.168.150.0/24 -p udp --dport 53 ! -i tun0 -j REDIRECT --to-ports 53 || \
iptables -t nat -A PREROUTING -s 192.168.150.0/24 -p udp --dport 53 ! -i tun0 -j REDIRECT --to-ports 53
iptables -t nat -C PREROUTING -s 192.168.151.0/24 -p udp --dport 53 ! -i tun0 -j REDIRECT --to-ports 30153 || \
iptables -t nat -A PREROUTING -s 192.168.151.0/24 -p udp --dport 53 ! -i tun0 -j REDIRECT --to-ports 30153
iptables -t nat -C OUTPUT -d 9.9.9.9 -p tcp --dport 53 -j REDIRECT --to-ports 30001 || \
iptables -t nat -A OUTPUT -d 9.9.9.9 -p tcp --dport 53 -j REDIRECT --to-ports 30001
iptables -t nat -C PREROUTING -s 192.168.152.0/24 -p udp --dport 53 ! -i tun0 -j REDIRECT --to-ports 30253 || \
iptables -t nat -A PREROUTING -s 192.168.152.0/24 -p udp --dport 53 ! -i tun0 -j REDIRECT --to-ports 30253
iptables -t nat -C OUTPUT -d 8.8.4.4 -p tcp --dport 53 -j REDIRECT --to-ports 30002 || \
iptables -t nat -A OUTPUT -d 8.8.4.4 -p tcp --dport 53 -j REDIRECT --to-ports 30002
iptables -t nat -C PREROUTING -s 192.168.153.0/24 -p udp --dport 53 ! -i tun0 -j REDIRECT --to-ports 30353 || \
iptables -t nat -A PREROUTING -s 192.168.153.0/24 -p udp --dport 53 ! -i tun0 -j REDIRECT --to-ports 30353
iptables -t nat -C OUTPUT -d 1.1.1.1 -p tcp --dport 53 -j REDIRECT --to-ports 30003 || \
iptables -t nat -A OUTPUT -d 1.1.1.1 -p tcp --dport 53 -j REDIRECT --to-ports 30003
iptables -t nat -C PREROUTING -s 192.168.154.0/24 -p udp --dport 53 ! -i tun0 -j REDIRECT --to-ports 30453 || \
iptables -t nat -A PREROUTING -s 192.168.154.0/24 -p udp --dport 53 ! -i tun0 -j REDIRECT --to-ports 30453
iptables -t nat -C OUTPUT -d 1.0.0.1 -p tcp --dport 53 -j REDIRECT --to-ports 30004 || \
iptables -t nat -A OUTPUT -d 1.0.0.1 -p tcp --dport 53 -j REDIRECT --to-ports 30004
